# Porta em que o servidor Express vai rodar
PORT=3333

# Ambiente de execução: development | production | test
NODE_ENV=development

# Segredo usado para assinar e validar os tokens JWT.
# Obrigatório -- a aplicação não sobe sem essa variável (ver src/config/env.ts).
# O valor abaixo serve só para desenvolvimento local; nunca reutilize
# em produção -- gere um valor forte, por exemplo: openssl rand -base64 32
JWT_SECRET=chave-secreta-apenas-para-desenvolvimento-local

# Connection string do PostgreSQL (via Supabase).
# Formato: postgresql://usuario:senha@host:porta/banco?schema=public
DATABASE_URL=